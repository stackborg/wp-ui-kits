# Auto-detect text files and ensure LF line endings
* text=auto

# ── Export Ignore ─────────────────────────────────
# Files excluded from the distributed package

# Development & CI
/.github/           export-ignore
/.editorconfig      export-ignore
/eslint.config.js   export-ignore
/tsconfig.json      export-ignore
/vitest.config.ts   export-ignore

# Tests
/tests/             export-ignore

# Documentation (dev-only)
/DEVELOPER_GUIDE.md export-ignore
/SECURITY.md        export-ignore
/CONTRIBUTING.md    export-ignore

# Distribution config (not needed in dist itself)
/.distignore        export-ignore
/.gitattributes     export-ignore
/.gitignore         export-ignore
